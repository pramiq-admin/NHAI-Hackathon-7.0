# === Backend ===
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/nhai_faceauth
JWT_SECRET_KEY=change-me-to-a-random-256-bit-key
JWT_ALGORITHM=RS256

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
RDS_ENDPOINT=

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# Model signing
MODEL_SIGNING_PRIVATE_KEY_PATH=~/.keys/model_signing_ed25519

# Play Integrity
PLAY_INTEGRITY_DECRYPTION_KEY=
PLAY_INTEGRITY_VERIFICATION_KEY=

# === Frontend (React Native) ===
# These go in frontend/.env (loaded via react-native-config)
API_BASE_URL=https://your-server.example.com/api/v1
FIREBASE_REMOTE_CONFIG_MIN_FETCH_INTERVAL=3600
