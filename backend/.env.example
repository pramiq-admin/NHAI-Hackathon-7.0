# NHAI Backend — environment template.
# Copy to `.env` and fill every REQUIRED value before booting.
#
# Generate strong secrets with:
#   python -c "from app.config import generate_secret; print(generate_secret())"

# ---------- Environment mode ----------
# `dev` or `production`. In `production` the app refuses to boot if any
# secret below is still at its placeholder default.
ENV=dev

# ---------- Postgres ----------
# REQUIRED — rotate these for each deployment.
# Either set the parts below (app + alembic compose DATABASE_URL automatically)
# OR set DATABASE_URL explicitly (overrides the parts). Use explicit form for
# managed Postgres with SSL / non-standard params:
#   DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/db?ssl=require
POSTGRES_USER=nhai
POSTGRES_PASSWORD=CHANGE_ME_postgres_password_replace_for_real_deploy
POSTGRES_DB=nhai_face
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# DATABASE_URL=        # uncomment to override the composed URL

# ---------- JWT ----------
# REQUIRED — must be a strong random 32+ byte value in production.
JWT_SECRET=CHANGE_ME_jwt_secret_must_be_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15
JWT_LEEWAY_SECONDS=30

# ---------- Aadhar pepper (REQUIRED in production) ----------
# Server-side-only secret mixed into every Aadhar HMAC. Without this, a DB
# leak alone is enough to brute-force the 10^11 Aadhar number space in
# seconds. Generate with `python -c 'from app.config import generate_secret; print(generate_secret())'`.
AADHAR_PEPPER=CHANGE_ME_aadhar_pepper_must_be_long_random_string

# ---------- CORS ----------
# JSON array. In production set to your front-door host(s). The app refuses
# to boot in production if this contains "*".
# Example: ["https://nhai.example.com","https://admin.nhai.example.com"]
CORS_ORIGINS=["*"]

# ---------- Legacy device-token flow ----------
# `false` (default) → /api/v1/auth/token returns 410 Gone. The legacy
# VerificationScreen-driven attendance uploader breaks. Set to `true` only
# if you also rotate DEVICE_SHARED_SECRET away from default.
DEVICE_TOKEN_ENABLED=false
DEVICE_SHARED_SECRET=disabled

# ---------- Prometheus /metrics ----------
# When empty, /metrics is not exposed at all (404). Set to a token to expose
# behind `Authorization: Bearer <token>`.
METRICS_BEARER_TOKEN=

# ---------- Play Integrity ----------
# `true` → reject requests missing the X-Integrity-Token header.
# Also requires the OAuth2 service-account wiring noted in
# `app/auth/play_integrity.py`'s TODO.
INTEGRITY_REQUIRED=false

# ---------- Grafana ----------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_admin_password
